# Supabase public client config (required for production auth/realtime/database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias for newer Supabase publishable keys. If both are present, ANON_KEY is used first.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Never expose this key to the browser. Used only by Stripe webhook/server routes.
SUPABASE_SERVICE_ROLE_KEY=

# Public application URL. For Hugging Face Space use: https://galym7707-chess-nfactorial.hf.space
NEXT_PUBLIC_APP_URL=http://localhost:7860
NEXT_PUBLIC_DEFAULT_LOCALE=ru

# Stripe client-side options. Use either Pricing Table or Payment Link.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_TABLE_ID=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Stripe server-side checkout/webhook options. Optional until real payments are enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
